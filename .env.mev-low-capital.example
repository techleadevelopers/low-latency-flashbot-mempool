# ============================================================
# LOW CAPITAL MEV ENGINE - SHADOW FIRST
# ============================================================
BOT_MODE=shadow
ALLOW_SEND=false
NETWORK=ethereum
CHAIN_ID=1

# RPC / relay
ALCHEMY_KEY=SEU_ALCHEMY_KEY
INFURA_ID_1=SEU_INFURA_1
FLASHBOTS_RELAY=https://relay.flashbots.net
MEMPOOL_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/SEU_ALCHEMY_KEY

# Required by existing binary config loader.
SENDER_PRIVATE_KEY=0xSUA_WALLET_SEARCHER
CONTROL_ADDRESS=0xSUA_TESOURARIA
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Disable legacy residual sweeper sends.
DISABLE_PUBLIC_FALLBACK=true
ENABLE_MEMPOOL_MONITOR=false

# ============================================================
# MEV ENGINE
# ============================================================
MEV_ENGINE_ENABLED=true
MEV_STRATEGY=backrun

# Capital preservation
MEV_CAPITAL_ETH=0.05
MEV_MAX_DAILY_LOSS_ETH=0.01
MEV_MAX_GAS_SPEND_WINDOW_ETH=0.003
MEV_GAS_SPEND_WINDOW_SECS=900
MEV_MAX_ALLOCATION_BPS=2500
MEV_EXECUTION_COOLDOWN_MS=30000

# Strict opportunity gates
MEV_MIN_LARGE_SWAP_ETH=25.0
MEV_MIN_NET_PROFIT_ETH=0.0025
MEV_MIN_PROFIT_USD=2.0
MEV_ETH_USD_PRICE=3200.0
MEV_MIN_LIQUIDITY_ETH=25.0
MEV_MIN_ROI_BPS=1500
MEV_MAX_RISK_SCORE=30
MEV_MAX_COMPETITION_SCORE=25
MEV_MIN_CONFIDENCE_SCORE=80
MEV_MAX_PENDING_AGE_MS=1500
MEV_MAX_GAS_PER_TX=260000
MEV_MAX_PRICE_IMPACT_BPS=250
MEV_SLIPPAGE_PROTECTION_BPS=50
MEV_GAS_SAFETY_MARGIN_BPS=12500
MEV_ALLOW_PUBLIC_MEMPOOL=false
MEV_EXECUTOR_ADDRESS=0xSEU_MEV_EXECUTOR_DEPLOYADO
MEV_UNISWAP_V2_FACTORY=0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f
MEV_SEARCHER_RECIPIENT=0xSUA_WALLET_SEARCHER
MEV_BUILDER_RELAYS=https://relay.flashbots.net
MEV_INCLUSION_MIN_EV_USD=1.0
MEV_INCLUSION_MAX_ATTEMPTS=2
MEV_INCLUSION_BASE_TIP_BPS=800
MEV_INCLUSION_MAX_TIP_BPS=3500

# Paper simulation only
MEV_PAPER_FILL_PROBABILITY_BPS=6500

# ERC-20 notional estimation for token-input swaps.
# price_eth is token price denominated in ETH.
MONITORED_TOKENS_ETHEREUM=USDC:stable:0xA0b86991c6218b36c1d19d4a2e9eb0ce3606eb48:6:0.00032,WETH:other:0xC02aaA39b223FE8D0A0E5C4F27eAD9083C756Cc2:18:1.0

# Existing monitor/dashboard knobs
MIN_BALANCE=0.01
MIN_NET_PROFIT_ETH=0.001
MIN_ROI_BPS=500
SCAN_INTERVAL_MS=500
MIN_SCAN_INTERVAL_MS=250
MAX_SCAN_INTERVAL_MS=1500
SCAN_CONCURRENCY=8
BATCH_SCAN_SIZE=12
QUEUE_WORKERS=1
DASHBOARD_ADDR=127.0.0.1:8787
STORAGE_PATH=bot_state.sqlite
